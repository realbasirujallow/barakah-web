# Barakah web — npm configuration
#
# We avoid the deprecated `production` key here entirely — Railway sets
# `NPM_CONFIG_OMIT=dev` (the modern equivalent) at the service level, which
# keeps `npm install` from pulling devDependencies during the production
# image build. Setting `production=false` in this file would itself emit the
# `npm warn config production Use --omit=dev instead.` warning we want to
# avoid, so we deliberately don't.

# Peer-dep resolution — keep strict so dependency mismatches surface at install
# time rather than silently at runtime (Next.js 16 + React 19 has tight peer
# bounds we want to honor).
legacy-peer-deps=false

# Fetch retry policy — fail fast on flaky registry responses so CI builds
# don't hang indefinitely.
fetch-retries=3
fetch-retry-maxtimeout=30000
