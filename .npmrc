# Barakah web — npm configuration
#
# Explicitly disable the deprecated `production` flag so npm doesn't emit
# `npm warn config production Use --omit=dev instead.` during builds.
#
# Some build environments (Vercel, older Railway deploys, certain CI images)
# inject NPM_CONFIG_PRODUCTION=true into the environment. We rely on Next.js's
# own NODE_ENV + --omit=dev semantics instead of npm's deprecated flag.
production=false

# Peer-dep resolution — keep strict so dependency mismatches surface at install
# time rather than silently at runtime (Next.js 16 + React 19 has tight peer
# bounds we want to honor).
legacy-peer-deps=false

# Use long format progress + a 30 s fetch timeout so CI builds fail fast
# instead of hanging on flaky registry responses.
fetch-retries=3
fetch-retry-maxtimeout=30000
