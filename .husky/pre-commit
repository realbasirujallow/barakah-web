#!/usr/bin/env sh
# Barakah web pre-commit: fast checks only (<15s). Anything slower goes to CI.
# To bypass in an emergency:  git commit --no-verify
set -eu

echo "→ npm audit (high/critical)…"
npm audit --audit-level=high --production

echo "→ eslint…"
npm run lint

# Round 29: tsc --noEmit added after Round 28's middleware/proxy coexistence
# slipped past the hook. Incremental mode means repeat runs are fast
# (~2-3s on warm cache). If someone re-introduces a type error — or a
# Next 16 convention violation that trips the bundler's compile path —
# the commit is blocked locally instead of failing at deploy time.
echo "→ tsc --noEmit (types + Next conventions)…"
npx tsc --noEmit --incremental

# Full vitest + build run in CI.
# If you want a stronger local gate, uncomment the next line:
# echo "→ vitest…" && npm test -- --run

echo "✓ pre-commit ok"
